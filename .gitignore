**/dist
**/dist-ssr
**/build
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Environment Variables
**/.env
**/.env.local
**/.env.*.local

# Prisma / SQLite
**/backend/prisma/dev.db
**/backend/prisma/dev.db-journal

# OS files
.DS_Store
Thumbs.db

# VS Code / Editor settings
.vscode/
.idea/
*.swp
*.swo
